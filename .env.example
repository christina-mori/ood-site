# ============================================================
# Oracle of Desire — 环境变量清单
# 对应 lib/server/env.ts，未配置时所有服务自动降级到 demo/mock 模式
# ============================================================

# ── App ─────────────────────────────────────────────────────
# 生产环境填写真实域名，本地开发默认 http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Stripe ──────────────────────────────────────────────────
# Dashboard → Developers → API keys → Secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Developers → Webhooks → 选择 endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# 单一产品价格 ID（Dashboard → Products → 选择产品 → Price ID）
# 未配置时支付走 mock 模式
STRIPE_MANIFEST_PRICE_ID=price_...

# ── Supabase ─────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project Settings → API → service_role key（仅服务端使用，切勿暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend（邮件发送）────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...

# 发件人地址（需要在 Resend 中验证域名）
# 默认值: O.O.D <ritual@updates.ood.aura>
RESEND_FROM=O.O.D <ritual@updates.your-domain.com>

# ── PostHog（用户行为分析，可选）────────────────────────────
# https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# PostHog 数据中心，默认 https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Cloudflare Turnstile（表单人机验证，可选）───────────────
# https://dash.cloudflare.com → Turnstile → 创建 Widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# ── Matrix Agent Revenue（支付链接 + Webhook）──────────────
# 通过 mcp__receivable__create_link 创建，返回的 URL 填入对应变量
# webhook_secret 填入 AGENT_REVENUE_WEBHOOK_SECRET

# Webhook 签名验证密钥（创建 payment link 时返回，仅服务端使用）
AGENT_REVENUE_WEBHOOK_SECRET=whsec_...

# 5 个产品的 Matrix 支付链接（buy.stripe.com 格式 URL）
NEXT_PUBLIC_PAYMENT_LINK_RELATIONSHIP=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_CAREER=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_MONEY=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_HEALING=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_ALL_FIELD=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_CROSSOVER_BUNDLE=https://buy.stripe.com/...
NEXT_PUBLIC_PAYMENT_LINK_SIGNAL_WALLPAPER=https://buy.stripe.com/...
